# ─── Database ───
DATABASE_URL="postgresql://skillshub:skillshub@localhost:5432/skills_hub?schema=public"

# ─── JWT ───
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# ─── S3 / MinIO ───
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="skills-hub"
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"

# ─── Seed (首个 Owner) ───
SEED_OWNER_EMAIL="owner@example.com"
SEED_OWNER_NAME="Owner"
SEED_OWNER_PASSWORD="change-this-password"

# ─── App ───
NEXT_PUBLIC_APP_NAME="Skills Hub"
