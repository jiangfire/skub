# ─── Skills Hub Production Environment ───
# Copy to .env on the production server and fill in real values.
# NEVER commit the real .env file.

# ─── Database ───
# Use a strong password (min 32 chars recommended)
POSTGRES_PASSWORD="CHANGE_ME_TO_A_STRONG_PASSWORD"

# ─── JWT ───
# CRITICAL: Generate a random 64+ char string. Do NOT use the default.
# Example: openssl rand -base64 48
JWT_SECRET="CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING"
JWT_EXPIRES_IN="7d"

# ─── S3 / MinIO ───
# Use strong credentials for production MinIO
S3_ACCESS_KEY_ID="CHANGE_ME"
S3_SECRET_ACCESS_KEY="CHANGE_ME_TO_A_STRONG_SECRET"
S3_REGION="us-east-1"
S3_BUCKET="skills-hub"

# ─── Seed (First Owner Account) ───
# This account will be created on first run. Change password after login.
SEED_OWNER_EMAIL="admin@your-domain.com"
SEED_OWNER_NAME="Admin"
SEED_OWNER_PASSWORD="CHANGE_ME_TO_A_STRONG_PASSWORD"

# ─── Domain (for Caddy HTTPS) ───
DOMAIN="skills-hub.your-domain.com"

# ─── GitHub Container Registry (for CD pulls) ───
GITHUB_OWNER="jiangfire"

# ─── App ───
NEXT_PUBLIC_APP_NAME="Skills Hub"

# ─── Notifications (optional) ───
# Set to "true" to disable notifications (skipped + logged to console)
# NOTIFICATIONS_DISABLED="true"
